---
import ClientPagination from "@/components/common/ClientPagination.astro";
import type { UserSubjectCollection } from "@/types/bangumi";
import Card from "./Card.astro";
import FilterControls from "./FilterControls.astro";

interface Props {
	sectionId: string;
	items: UserSubjectCollection[];
	isActive: boolean;
	itemsPerPage?: number;
}

const { sectionId, items, isActive, itemsPerPage = 12 } = Astro.props;

// 状态映射
const statusMap = {
	1: "wish",
	2: "collect",
	3: "doing",
	4: "on_hold",
	5: "dropped",
};

// Get status filters with counts
const statusCounts = items.reduce(
	(acc, item) => {
		const status = statusMap[item.type as keyof typeof statusMap] || "unknown";
		acc[status] = (acc[status] || 0) + 1;
		return acc;
	},
	{} as Record<string, number>,
);

const isGame = sectionId === "game";
const isBook = sectionId === "book";
const isMusic = sectionId === "music";

const getFilterLabel = (type: "collect" | "doing" | "wish") => {
	if (isGame) {
		switch (type) {
			case "collect":
				return "已玩";
			case "doing":
				return "在玩";
			case "wish":
				return "想玩";
		}
	}
	if (isBook) {
		switch (type) {
			case "collect":
				return "已读";
			case "doing":
				return "在读";
			case "wish":
				return "想读";
		}
	}
	if (isMusic) {
		switch (type) {
			case "collect":
				return "已听";
			case "doing":
				return "在听";
			case "wish":
				return "想听";
		}
	}
	// Default (Anime/Real)
	switch (type) {
		case "collect":
			return "已看";
		case "doing":
			return "在看";
		case "wish":
			return "想看";
	}
};

const filters = [
	{ value: "all", label: "全部", count: items.length },
	{
		value: "collect",
		label: getFilterLabel("collect"),
		count: statusCounts.collect || 0,
	},
	{
		value: "doing",
		label: getFilterLabel("doing"),
		count: statusCounts.doing || 0,
	},
	{
		value: "wish",
		label: getFilterLabel("wish"),
		count: statusCounts.wish || 0,
	},
	{
		value: "on_hold",
		label: "搁置",
		count: statusCounts.on_hold || 0,
	},
	{
		value: "dropped",
		label: "抛弃",
		count: statusCounts.dropped || 0,
	},
].filter((filter) => filter.value === "all" || filter.count > 0);

const defaultFilter = "all"; // 默认显示全部，用户可以通过筛选器选择
---

<div class:list={["bangumi-section", { "hidden": !isActive }]} data-section={sectionId}>
  {items.length > 0 ? (
    <>
      <FilterControls
        filters={filters}
        activeFilter={defaultFilter}
        sectionId={sectionId}
      />

      <div class="bangumi-masonry" style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.75rem;">
				{items.map((item, index) => (
          <div
            class="bangumi-item"
            data-item-section={sectionId}
            data-item-status={statusMap[item.type as keyof typeof statusMap] || "unknown"}
						style={index < itemsPerPage ? undefined : "display: none;"}
          >
						<Card item={item} loadImage={isActive && index < itemsPerPage} />
          </div>
        ))}
      </div>

      <ClientPagination
        totalItems={items.length}
        itemsPerPage={itemsPerPage}
        currentPage={1}
        sectionId={sectionId}
      />
    </>
  ) : (
    <div class="text-center py-12">
      <h3 class="text-xl font-medium text-gray-600 dark:text-gray-400 mb-2">{"暂无数据"}</h3>
      <p class="text-gray-500 dark:text-gray-500">{"这里还没有内容，快去添加一些吧"}</p>
    </div>
  )}
</div>

<style is:global>
  @media (min-width: 640px) {
    .bangumi-masonry {
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)) !important;
    }
  }
</style>