---
import { sakuraConfig } from "@/config";

const config = sakuraConfig;
---

<script is:inline define:vars={{ sakuraConfig: config }}>
    let windowWidth = window.innerWidth;
    let windowHeight = window.innerHeight;

    // ── 单颗扬尘粒子 ──
    // 完全对齐 arknights 主题 canvaDust.ts 的实现：
    // 椭圆形、白色、带微弱阴影，整体向左上方缓慢飘移
    class Particle {
        constructor(x, y, config) {
            this.x = x;
            this.y = y;
            this.config = config;

            // 速度：vx 向左 (1~2)，vy 向上 (~0~1)，与原主题一致
            // 每帧执行 x -= vx; y -= vy → 朝左上方飞
            this.vx = Math.random() * 1 + 1;
            this.vy = Math.random() * 1 + 0.01;

            // 椭圆尺寸：扁平的尘粒
            this.radiusX = Math.random() * 1.5 + 0.5;
            this.radiusY = this.radiusX * (Math.random() * (1.3 - 0.3) + 0.3);
            this.rotation = Math.PI * Math.floor(Math.random() * 2);

            // 微弱柔光阴影
            this.shadowBlur = Math.random() * 3;
            this.shadowX = Math.random() * 2 - 1;
            this.shadowY = Math.random() * 2 - 1;
        }

        draw(ctx, color) {
            ctx.beginPath();
            ctx.shadowBlur = this.shadowBlur;
            ctx.shadowOffsetX = this.shadowX;
            ctx.shadowOffsetY = this.shadowY;
            ctx.shadowColor = color;
            ctx.fillStyle = color;
            ctx.ellipse(
                this.x,
                this.y,
                this.radiusX,
                this.radiusY,
                this.rotation,
                0,
                Math.PI * 2,
            );
            ctx.closePath();
            ctx.fill();
        }

        update() {
            // 飞出左边界或上边界后，从右侧边缘随机高度重新进入
            if (this.x < -5 || this.y < -5) {
                this.x = windowWidth;
                this.y = Math.floor(Math.random() * windowHeight);
            } else {
                this.x -= this.vx;
                this.y -= this.vy;
            }
        }
    }

    // ── 粒子管理器 ──
    class ParticleManager {
        constructor(config) {
            this.config = config;
            this.canvas = null;
            this.ctx = null;
            this.particles = [];
            this.animationId = null;
            this.isRunning = false;
        }

        init() {
            if (!this.config.enable || this.isRunning) {
                return;
            }
            this.createCanvas();
            this.createParticles();
            this.startAnimation();
            this.isRunning = true;
        }

        createCanvas() {
            this.canvas = document.createElement("canvas");
            this.canvas.width = windowWidth;
            this.canvas.height = windowHeight;
            this.canvas.setAttribute(
                "style",
                `position: fixed; left: 0; top: 0; pointer-events: none; z-index: ${this.config.zIndex}; transform: translateZ(0);`,
            );
            this.canvas.setAttribute("id", "canvas_particles");
            document.body.appendChild(this.canvas);
            this.ctx = this.canvas.getContext("2d");

            // 尘埃颜色：原主题为纯白，这里支持从 config.colors 取第一个颜色，缺省 #fff
            this._color = "#fff";
            this.ctx.fillStyle = this._color;
            this.ctx.shadowColor = this._color;

            this._boundHandleResize = this.handleResize.bind(this);
            window.addEventListener("resize", this._boundHandleResize);
        }

        createParticles() {
            // 数量与原主题一致：随屏幕尺寸自适应 (宽+高)/38
            // 若 config.sakuraNum 显式指定则优先使用
            const num =
                this.config.sakuraNum ||
                Math.floor((windowWidth + windowHeight) / 38);

            for (let i = 0; i < num; i++) {
                const x = Math.floor(Math.random() * windowWidth);
                const y = Math.floor(Math.random() * windowHeight);
                this.particles.push(new Particle(x, y, this.config));
            }
        }

        startAnimation() {
            if (!this.ctx || !this.canvas) return;

            const animate = () => {
                if (!this.ctx || !this.canvas) return;

                // 局部擦除旧位置（与原主题一致，高效重绘）
                const particles = this.particles;
                for (let i = 0; i < particles.length; i++) {
                    const p = particles[i];
                    this.ctx.clearRect(p.x - 6, p.y - 6, 12, 12);
                    p.update();
                }
                // 绘制新位置
                for (let i = 0; i < particles.length; i++) {
                    particles[i].draw(this.ctx, this._color);
                }

                this.animationId = requestAnimationFrame(animate);
            };

            this.animationId = requestAnimationFrame(animate);
        }

        handleResize() {
            windowWidth = window.innerWidth;
            windowHeight = window.innerHeight;
            if (this.canvas) {
                this.canvas.width = windowWidth;
                this.canvas.height = windowHeight;
                // resize 会重置 canvas 状态，需重新设置颜色
                this.ctx.fillStyle = this._color;
                this.ctx.shadowColor = this._color;
            }
        }

        stop() {
            if (this.animationId) {
                cancelAnimationFrame(this.animationId);
                this.animationId = null;
            }
            if (this.canvas) {
                document.body.removeChild(this.canvas);
                this.canvas = null;
            }
            if (this._boundHandleResize) {
                window.removeEventListener("resize", this._boundHandleResize);
                this._boundHandleResize = null;
            }
            this.particles = [];
            this.isRunning = false;
        }

        toggle() {
            if (this.isRunning) {
                this.stop();
            } else {
                this.init();
            }
        }

        updateConfig(newConfig) {
            const wasRunning = this.isRunning;
            if (wasRunning) {
                this.stop();
            }
            this.config = newConfig;
            if (wasRunning && newConfig.enable) {
                this.init();
            }
        }

        getIsRunning() {
            return this.isRunning;
        }
    }

    // ── 全局实例与初始化 ──
    let globalParticleManager = null;
    window.particleManager = null;

    function initParticles(config) {
        if (globalParticleManager) {
            globalParticleManager.updateConfig(config);
        } else {
            globalParticleManager = new ParticleManager(config);
            window.particleManager = globalParticleManager;
            if (config.enable) {
                globalParticleManager.init();
            }
        }
    }

    (function () {
        if (window.particleInitialized) {
            return;
        }

        // 兼容旧版 sakuraManager 引用
        window.sakuraManager = {
            getIsRunning: () =>
                globalParticleManager
                    ? globalParticleManager.getIsRunning()
                    : false,
            toggle: () => {
                if (globalParticleManager) globalParticleManager.toggle();
            },
            stop: () => {
                if (globalParticleManager) globalParticleManager.stop();
            },
            init: () => {
                if (globalParticleManager) globalParticleManager.init();
            },
        };

        const setupParticles = () => {
            if (window.particleInitialized) return;
            const storedEnabled = localStorage.getItem("sakuraEnabled");
            const isEnabled =
                storedEnabled !== null
                    ? storedEnabled === "true"
                    : sakuraConfig.enable;
            const cfg = Object.assign({}, sakuraConfig, { enable: isEnabled });
            initParticles(cfg);
            window.particleInitialized = true;
        };

        if (document.readyState === "loading") {
            document.addEventListener("DOMContentLoaded", setupParticles);
        } else {
            setupParticles();
        }
    })();

    // 监听设置面板的特效切换事件（兼容旧 sakuraToggle 事件名）
    window.addEventListener("sakuraToggle", function (e) {
        const enabled = e.detail.enabled;
        const mgr = globalParticleManager;
        if (!mgr) return;
        if (enabled && !mgr.getIsRunning()) {
            mgr.config.enable = true;
            mgr.init();
        } else if (!enabled && mgr.getIsRunning()) {
            mgr.stop();
        }
    });
</script>
