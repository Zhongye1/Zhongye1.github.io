---
import ReferrerPolicyScript from "@components/boot/ReferrerPolicyScript.astro";
import SettingsBootScript from "@components/boot/SettingsBootScript.astro";
// ── 启动脚本(is:inline 防闪烁) ──────────────────────────────
import ThemeBootScript from "@components/boot/ThemeBootScript.astro";
import WallpaperBootScript from "@components/boot/WallpaperBootScript.astro";
// ── 业务组件 ─────────────────────────────────────────────────
import FancyboxManager from "@components/features/FancyboxManager.astro";
import FontManager from "@components/features/FontManager.astro";
import MusicManager from "@components/features/MusicManager.astro";
import SakuraEffect from "@components/features/SakuraEffect.astro";
import AnalyticsBundle from "@components/head/AnalyticsBundle.astro";
import Favicons from "@components/head/Favicons.astro";
// ── Head 子组件 ────────────────────────────────────────────
import MetaTags from "@components/head/MetaTags.astro";
import RssLink from "@components/head/RssLink.astro";
import ConfigCarrier from "@components/layout/ConfigCarrier.astro";

import { backgroundWallpaper, siteConfig } from "@/config";
import { SITE_LANG } from "@/config/siteConfig";
import {
	BANNER_HEIGHT,
	BANNER_HEIGHT_HOME,
	PAGE_WIDTH,
} from "@/constants/constants";
import { getDefaultBackground, isHomePage } from "@/utils/layout-utils";

import "@/styles/main.css";
import "@/styles/variables.styl";
import "@/styles/markdown-extend.styl";
// import "@rehype-callouts-theme";

interface Props {
	title?: string;
	banner?: string;
	description?: string;
	lang?: string;
	setOGTypeArticle?: boolean;
	postSlug?: string;
}

let { title, banner, description, lang, setOGTypeArticle, postSlug } =
	Astro.props;

// apply a class to the body element to decide the height of the banner, only used for initial page load
// Swup can update the body for each page visit, but it's after the page transition, causing a delay for banner height change
// so use Swup hooks instead to change the height immediately when a link is clicked
const isHomePageCheck = isHomePage(Astro.url.pathname);

// defines global css variables
const configHue = siteConfig.themeColor.hue;

// 获取导航栏透明模式配置
const navbarTransparentMode =
	backgroundWallpaper.common?.navbar?.transparentMode || "semi";
// 判断是否应该显示顶部高光效果（只在full和semifull模式下显示）
const shouldShowTopHighlight =
	navbarTransparentMode === "full" || navbarTransparentMode === "semifull";

if (!banner || typeof banner !== "string" || banner.trim() === "") {
	banner = getDefaultBackground();
}

// TODO don't use post cover as banner for now
banner = getDefaultBackground();

const enableBanner = backgroundWallpaper.mode === "banner";

let ogImageUrl: string | undefined;
if (siteConfig.generateOgImages && postSlug) {
	ogImageUrl = new URL(`/og/${postSlug}.png`, Astro.site).toString();
}

if (!lang) {
	lang = SITE_LANG;
}
const siteLang = lang.replace("_", "-");
---

<!doctype html>
<html
    lang={siteLang}
    class="bg-(--page-bg) text-[14px] md:text-[16px]"
    data-wallpaper-mode={backgroundWallpaper.mode}
>
    <head>
        <meta charset="UTF-8" />

        <!-- 分析脚本 -->
        <AnalyticsBundle />

        <!-- 元标签 & SEO -->
        <MetaTags
            title={title}
            description={description}
            setOGTypeArticle={setOGTypeArticle}
            ogImageUrl={ogImageUrl}
        />

        <!-- Favicons -->
        <Favicons />

        <!-- referrerpolicy 防盗链 -->
        <ReferrerPolicyScript />

        <!-- 启动脚本（防闪烁，is:inline） -->
        <ThemeBootScript />
        <WallpaperBootScript />
        <SettingsBootScript />

        <slot name="head" />

        <!-- RSS -->
        <RssLink />

        <!-- Font Manager -->
        <FontManager />
    </head>
    <body
        class="min-h-screen"
        class:list={[
            {
                "is-home": isHomePageCheck,
                "lg:is-home": isHomePageCheck,
                "enable-banner": enableBanner,
                "sticky-navbar": siteConfig.navbar.stickyNavbar ?? false,
                "enable-card-border": siteConfig.card?.border,
                "card-follow-theme-hue": siteConfig.card?.followTheme,
            },
            ...(siteConfig.font.enable && siteConfig.font.selected
                ? (Array.isArray(siteConfig.font.selected)
                      ? siteConfig.font.selected
                      : [siteConfig.font.selected]
                  ).map((fontId) => `font-${fontId}-enabled`)
                : []),
        ]}
    >
        <div id="progress-bar"></div>

        <!-- 页面顶部渐变高光效果 - 只在full和semifull模式下显示 -->
        {shouldShowTopHighlight && <div class="top-gradient-highlight" />}
        <ConfigCarrier />
        <MusicManager />
        <slot />

        <!-- Sakura Effect -->
        <SakuraEffect />

        <!-- Fancybox Manager -->
        <FancyboxManager />
    </body>
</html>

<!-- CSS 变量注入（banner 高度等运行时配置） -->
<style
    define:vars={{
        configHue,
        "page-width": `${siteConfig.pageWidth ?? PAGE_WIDTH}rem`,
        "banner-height-home": `${BANNER_HEIGHT_HOME}vh`,
        "banner-height": `${BANNER_HEIGHT}vh`,
    }}
></style>

<!-- 运行时脚本入口 -->
<script>
    import "@/scripts";
</script>
